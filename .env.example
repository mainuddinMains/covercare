AUTH_SECRET=your-random-secret-here
AUTH_BASE_URL=http://localhost:5173

# for auth urls to work from localhost
DEV_MODE=true

# Get your API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_key_here
OPENROUTER_MODELS=deepseek/deepseek-v3.2,openai/gpt-4o-mini

# Google Places API (for hospital finder)
# https://console.cloud.google.com/apis/credentials
GOOGLE_PLACES_API_KEY=your_key_here

# CMS Marketplace API -- optional, increases rate limits
# Register at: https://developer.cms.gov/
CMS_MARKETPLACE_API_KEY=

# GoodRx API -- requires business partnership
# Apply at: https://www.goodrx.com/business/solutions/api
GOODRX_CLIENT_ID=
GOODRX_API_KEY=

# Open211 API -- requires API key
# Apply at: https://api.211.org/
OPEN211_API_KEY=

# Zocdoc Partner API -- requires business partnership
# Apply at: https://www.zocdoc.com/about/developer-api/
ZOCDOC_API_KEY=
