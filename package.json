{
  "name": "care-compass",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node dev.mjs",
    "bri": "node dev.mjs --no-portless",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "vite build && wrangler deploy",
    "lint": "eslint",
    "format": "prettier",
    "check": "prettier --write . && eslint --fix",
"db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply care-compass-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply care-compass-db --remote"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "workerd"
    ],
    "patchedDependencies": {}
  },
  "dependencies": {
    "@fontsource-variable/dm-sans": "^5.2.8",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource/lora": "^5.2.8",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/ai": "^0.10.1",
    "@tanstack/ai-openrouter": "^0.7.3",
    "@tanstack/ai-react": "^0.7.9",
    "@tanstack/react-router": "^1.168.18",
    "@tanstack/react-start": "^1.167.32",
    "better-auth": "^1.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.8.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "vite-tsconfig-paths": "^5.1.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.31.2",
    "@cloudflare/workers-types": "^4.20260412.1",
    "@tanstack/eslint-config": "^0.4.0",
    "@tanstack/router-plugin": "^1.167.18",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "drizzle-kit": "^0.31.10",
    "portless": "^0.6.0",
    "prettier": "^3.8.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "wrangler": "^4.81.1"
  }
}