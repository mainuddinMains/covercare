# OpenRouter — get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_key_here
# Google Places API — enable "Places API (New)" in Google Cloud Console
GOOGLE_PLACES_API_KEY=

# Optional: override the default model (gpt-4o-mini)
# OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# Your deployed URL (used for OpenRouter HTTP-Referer header)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
